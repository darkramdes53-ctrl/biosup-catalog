{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/darkramdes53-ctrl/biosup-catalog/schemas/catalog.schema.json",
  "title": "BiosUP catalog index",
  "type": "object",
  "required": ["schemaVersion", "updatedAt", "vendors"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 2 },
    "catalogVersion": { "type": "string" },
    "updatedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "description": { "type": "string" },
    "vendors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["manufacturer", "path"],
        "properties": {
          "manufacturer": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "pattern": "^vendors/[a-z0-9_-]+\\.json$" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
