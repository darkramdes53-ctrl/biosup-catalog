{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/darkramdes53-ctrl/biosup-catalog/schemas/vendor.schema.json",
  "title": "BiosUP vendor catalog",
  "type": "object",
  "required": ["manufacturer", "aliases", "officialDomains", "genericRules", "models"],
  "properties": {
    "manufacturer": { "type": "string", "minLength": 1 },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "officialDomains": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "genericRules": { "type": "object", "additionalProperties": true },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["model"],
        "properties": {
          "model": { "type": "string", "minLength": 1 },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "supportSlug": { "type": "string" },
          "supportPageUrl": { "type": "string" },
          "boardId": { "type": "string" },
          "revision": { "type": "string" },
          "revisionRequired": { "type": "boolean" },
          "safeWithoutRevision": { "type": "boolean" },
          "expectedBiosFilePattern": { "type": "string" },
          "confidence": { "type": "string" },
          "lastChecked": { "type": "string" },
          "source": { "type": "string" },
          "notes": { "type": "array", "items": { "type": "string" } },
          "latestBios": { "type": ["object", "null"], "additionalProperties": true },
          "verifiedLatestBios": { "type": ["object", "null"], "additionalProperties": true },
          "revisionPages": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
